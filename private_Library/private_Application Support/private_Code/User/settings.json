  "git.autofetch": true,
  "git.confirmSync": false, // UX
  "git.blame.editorDecoration.enabled": true,
  "git.blame.statusBarItem.enabled": true,
  "git.blame.statusBarItem.template": "${authorDateAgo}",
  "gitlens.plusFeatures.enabled": false,
  // Git Diff
  "diffEditor.ignoreTrimWhitespace": false, // Харах шаардлагагүй
  "diffEditor.experimental.showMoves": true, // Refactor хийсний дараа хянахад ойлгомжтой
  "diffEditor.hideUnchangedRegions.enabled": true,
  "diffEditor.hideUnchangedRegions.minimumLineCount": 3,
  "diffEditor.hideUnchangedRegions.contextLineCount": 3,
  "diffEditor.renderSideBySide": true, // Илүү ойлгомжтой
  "scm.alwaysShowRepositories": true,
  "scm.defaultViewMode": "tree", // Tree гээр харвал directory бүрээр нь хуваадаг тул ойлгомжтой
  "scm.repositories.sortOrder": "path", // Илүү цэгц
  "gitlens.remotes": [
    {
      "domain": "git.ictgroup.mn",
      "type": "GitLab"
    }
  ], // Optional
  "gitlens.hovers.currentLine.over": "annotation",
  "gitlens.currentLine.enabled": false,
  "gitlens.views.scm.grouped.views": {
    "commits": true,
    "branches": true,
    "remotes": true,
    "stashes": true,
    "tags": true,
    "worktrees": true,
    "contributors": true,
    "repositories": true,
    "searchAndCompare": true,
    "launchpad": true
  },
  "git.showPushSuccessNotification": true,
  "workbench.navigationControl.enabled": false,
  "workbench.layoutControl.enabled": false,
}