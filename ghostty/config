term = xterm-256color
# font-family = "FiraCode Nerd Font"
# font-family = "GeistMono Nerd Font"
# font-family = "ZedMono NFM"
font-family = "ZedMono NFM Extd"
font-size = 20

link-url = true
background-opacity = 0.9
background-blur = true

scrollback-limit = 50000

theme = Kanagawa Dragon
desktop-notifications = true

# window-padding-y = 2,0
# window-padding-balance = true
window-decoration = false
# macos-titlebar-style = hidden

# macos-titlebar-style = native
# copy-on-select = clipboard
# app-notifications = no-clipboard-copy

# custom-shader = shaders/cursor_sweep.glsl
# custom-shader = shaders/cursor_tail.glsl
# custom-shader = shaders/cursor_warp.glsl
# custom-shader = shaders/just_snow.glsl
# custom-shader = shaders/rectangle_boom_cursor.glsl
# custom-shader = shaders/ripple_cursor.glsl
# custom-shader = shaders/ripple_rectangle_cursor.glsl

# Forward modified arrows to terminal apps instead of consuming them in Ghostty.
keybind = shift+arrow_left=text:\x1b[1;2D
keybind = shift+arrow_right=text:\x1b[1;2C
keybind = shift+arrow_up=text:\x1b[1;2A
keybind = shift+arrow_down=text:\x1b[1;2B

# keybind = page_up=scroll_page_up
# keybind = page_down=scroll_page_down
keybind = super+k=text:\x01K
