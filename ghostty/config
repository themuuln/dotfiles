# Tmux-style leader bindings copied from ~/.config/tmux/tmux.conf.
# Mapping model:
# - tmux windows -> Ghostty tabs
# - tmux panes -> Ghostty splits
# - tmux sessions -> Ghostty windows
# Unsupported tmux-only actions are intentionally left unbound.

# No-prefix tmux navigation
keybind = shift+arrow_left=previous_tab
keybind = shift+arrow_right=next_tab
keybind = ctrl+shift+tab=previous_tab
keybind = ctrl+tab=next_tab
keybind = cmd+shift+left_bracket=previous_tab
keybind = cmd+shift+right_bracket=next_tab
keybind = shift+arrow_up=goto_window:previous
keybind = shift+arrow_down=goto_window:next
keybind = performable:ctrl+h=goto_split:left
keybind = performable:ctrl+j=goto_split:down
keybind = performable:ctrl+k=goto_split:up
keybind = performable:ctrl+l=goto_split:right

# Prefix (leader) mappings using the tmux prefix: Ctrl-A
keybind = ctrl+a>escape=end_key_sequence
keybind = ctrl+a>ctrl+a=last_tab
keybind = ctrl+a>ctrl+c=new_tab
keybind = ctrl+a>ctrl+l=reset

keybind = ctrl+a>shift+h=previous_tab
keybind = ctrl+a>shift+l=next_tab

keybind = ctrl+a>r=prompt_tab_title
keybind = ctrl+a>shift+r=reload_config
keybind = ctrl+a>i=inspector:toggle
keybind = ctrl+a>z=toggle_split_zoom
keybind = ctrl+a>shift+k=clear_screen

keybind = ctrl+a>s=new_split:down
keybind = ctrl+a>v=new_split:right
keybind = ctrl+a>shift+backslash=new_split:right

keybind = ctrl+a>h=goto_split:left
keybind = ctrl+a>j=goto_split:down
keybind = ctrl+a>k=goto_split:up
keybind = ctrl+a>l=goto_split:right

keybind = ctrl+a>comma=resize_split:left,180
keybind = ctrl+a>period=resize_split:right,180
keybind = ctrl+a>minus=resize_split:down,120
keybind = ctrl+a>plus=resize_split:up,120
keybind = ctrl+a>equal=equalize_splits

keybind = ctrl+a>c=close_surface
keybind = ctrl+a>shift+semicolon=toggle_command_palette

# Left out because Ghostty has no close native equivalent:
# detach, list windows/sessions/clients, synchronize-panes, swap-pane,
# tmux popups, tmux menus, and copy-mode-specific bindings.
